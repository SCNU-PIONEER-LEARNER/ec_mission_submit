{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "jlink-Debug",
      "executable": "./build/CanMotors.elf",
      "type": "cortex-debug",
      "request": "launch",
      "showDevDebugOutput": "none",
      "servertype": "jlink",
      "device": "stm32f407ig",
      "liveWatch": {
        "enabled": true,
        "samplesPerSecond": 1
      },
      "preLaunchTask": "Build",
      "rttConfig": {
        "enabled": true,
        "address": "auto",
        "polling_interval": 10,
        "decoders": [
          {
            "type": "console",
            "label": "cnt",
            "noclear": false,
            "logfile": "${workspaceRoot}/.docs/rtt.log",
            "port": 0
          }
        ]
      }
    },
    {
      "showDevDebugOutput": "none",
      "cwd": "${workspaceFolder}",
      "executable": "./build/CanMotors.elf",
      "name": "dap",
      "request": "launch",
      "type": "cortex-debug",
      "servertype": "openocd",
      "configFiles": [
        "interface/cmsis-dap.cfg",
        "target/stm32f4x.cfg"
      ],
      // "svdFile": "docs/startup/STM32H723.svd",
      "liveWatch": {
        "enabled": true,
        "samplesPerSecond": 1
      },
      "preLaunchTask": "Build",
      // "overrideLaunchCommands": [  // 不复位debug
      //     "monitor  halt",
      // ],
      //   "overrideResetCommands": [
      //     "monitor  halt",
      // ], // "postDebugTask": "close-RTT",
      "rttConfig": {
        "enabled": true,
        "address": "auto",
        "polling_interval": 10,
        "decoders": [
          {
            "type": "console",
            "label": "cnt",
            "noclear": false,
            "logfile": "${workspaceRoot}/.docs/rtt.log",
            "port": 0
          }
        ]
      }
    },
    {
      "showDevDebugOutput": "none",
      "cwd": "${workspaceFolder}",
      "executable": "./build/PinyCore.elf",
      "name": "stlink",
      "request": "launch",
      "type": "cortex-debug",
      "servertype": "openocd",
      "configFiles": [
        "${workspaceFolder}/tools/openocd/stlink.cfg",
        "target/stm32f4x.cfg"
      ],
      // "svdFile": "docs/startup/STM32H723.svd",
      "liveWatch": {
        "enabled": true,
        "samplesPerSecond": 1
      },
      "preLaunchTask": "build",
      // "overrideLaunchCommands": [  // 不复位debug
      //     "monitor  halt",
      // ],
      //   "overrideResetCommands": [
      //     "monitor  halt",
      // ],
      // "postDebugTask": "close-RTT",
      "rttConfig": {
        "enabled": true,
        "address": "auto",
        "polling_interval": 10,
        "decoders": [
          {
            "type": "console",
            "label": "cnt",
            "noclear": false,
            "logfile": "${workspaceRoot}/.docs/rtt.log",
            "port": 0
          }
        ]
      }
    }
  ]
}
